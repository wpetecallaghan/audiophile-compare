# Copy this file to .env.local and fill in real values.
# See docs/dependencies.md "Environment variables" for where to find each
# one, and docs/supabase-environments.md for the staging/production project
# split this app uses.

# Supabase staging project (Settings -> API in the staging project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# Cron endpoint protection (any random secret string)
CRON_SECRET=<random-secret>

# /version page access -- comma-separated allowlist, no schema/role involved
ADMIN_EMAILS=you@example.com

# --- E2E tests only (see docs/end-to-end-testing.md) ---
# E2E_TEST_USER_EMAIL=e2e-tests@example.com
# E2E_BASE_URL=http://localhost:3000
# VERCEL_AUTOMATION_BYPASS_SECRET=<only if E2E_BASE_URL points at a Vercel-protected deployment>

# --- Forum ingestion scripts only, local-script-only (see docs/vercel-setup.md) ---
# AI_GATEWAY_API_KEY=<for scripts/extract-lejonklou.ts>
# INGEST_SECRET_STAGING=<for scripts/commit-lejonklou.ts --env staging>
# INGEST_SECRET_PRODUCTION=<for scripts/commit-lejonklou.ts --env production>
# COMMIT_BASE_URL_STAGING=https://staging.example.com
# COMMIT_BASE_URL_PRODUCTION=https://example.com
# SUPABASE_URL_STAGING=<for scripts/rollback-lejonklou.ts --env staging>
# SUPABASE_SERVICE_ROLE_KEY_STAGING=<for scripts/rollback-lejonklou.ts --env staging>
# SUPABASE_URL_PRODUCTION=<for scripts/rollback-lejonklou.ts --env production>
# SUPABASE_SERVICE_ROLE_KEY_PRODUCTION=<for scripts/rollback-lejonklou.ts --env production>
